@import url(http://fonts.googleapis.com/css?family=Montserrat)

html
  color: #000
  background: #FFF
  background: #bababa url('../images/prashant_bg.png') right top no-repeat
  font-family: 'Montserrat', sans-serif

.content
  background: #ffffff
  min-height: 85%
  opacity: 0.9
  width: 54%
  padding: 20px 20px 0px 20px
  line-height: 2em
  text-align: justify

a
  text-decoration: none

a:hover
  text-decoration: underline
  font-weight: 900

ul
  list-style-type: disc

.blog-link
  margin-left: 10px

.social-links
  margin-top: 5px
  float: right

.social-link
  padding:  10px

a.social-link:hover
  text-decoration: none